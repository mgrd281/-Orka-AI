# === Orka AI Backend Environment ===

# App
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-secure-random-string
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://orka:orka@localhost:5432/orka_ai
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET_KEY=change-me-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Supabase (optional, for auth/storage)
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=

# AI Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Default Models
DEFAULT_FAST_MODEL=gpt-4o-mini
DEFAULT_SMART_MODEL=gpt-4o
DEFAULT_DEEP_MODEL=claude-sonnet-4-20250514

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_PREMIUM_PRICE_ID=

# Analytics
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.posthog.com

# Sentry
SENTRY_DSN=

# Storage
S3_BUCKET=
S3_REGION=eu-central-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
